    },

    maskKeyDisplay(keyStr) {
      if (keyStr && keyStr.length > 12) {
        this.maskedKey = keyStr.substring(0, 7) + '...' + keyStr.substring(keyStr.length - 4);
      } else {
        this.maskedKey = 'Active Secured';
      }
    },

    toggleQrScale() {
      this.isQrFullscreen = !this.isQrFullscreen;
    },

    proceedToChat() {
      this.stopPolling();
      router.replace({ uri: '/pages/chat' });
    },

    handleGoBack() {
      this.stopPolling();
      router.replace({ uri: '/pages/index' });
    }
  }
</script>

