    onShow() {
      if (this.clearKey === 'true' || this.clearKey === true) {
        this.wipeCorruptStorage();
      } else {
        this.checkStoredKey();
      }
    },

    onDestroy() {
      this.isPageDestroyed = true;
      this.stopPolling();
    },

    wipeCorruptStorage() {
      storage.delete({
        key: 'API_KEY',
        complete: () => {
          this.clearKey = 'false';
          this.rawApiKey = '';
          this.maskedKey = 'No Token Linked';
          this.syncStatus = 'Waiting for web sync...';
          this.statusDotClass = 'bg-blue';
          this.statusTextClass = 'text-blue';
          this.preparePairing();
        }
      });
    },

